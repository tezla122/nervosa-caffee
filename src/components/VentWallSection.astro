---
// VentWallSection.astro — Anonymous vent board with corkboard layout
import TornEdge from './svg/TornEdge.astro';
---

<section id="vent-wall" class="section section-paper ventwall-section">
  <TornEdge direction="top" fill="var(--deep-black)" />
  <div class="ventwall-container">
    <h2 class="ventwall-title heading-tilt-left tear-in">
      <span class="ventwall-label font-mono">// zidul</span>
      Aruncă un gând.
    </h2>
    <p class="ventwall-subtitle font-mono tear-in">
      Anonim. Dispare în 24h. Fără judecată.
    </p>

    <!-- Post form -->
    <div class="vent-form-wrapper tear-in">
      <textarea
        id="vent-textarea"
        class="vent-textarea"
        maxlength="140"
        placeholder="Ce te macină azi? (max 140 caractere)"
        aria-label="Scrie un gând anonim"
      ></textarea>
      <div class="vent-form-footer">
        <span class="vent-char-count font-mono" id="vent-char-count">0 / 140</span>
        <button class="btn-nervosa" id="vent-submit" type="button">
          aruncă gândul
        </button>
      </div>
      <div class="overthinking-loader" id="vent-loader" style="display: none;"></div>
    </div>

    <!-- Corkboard -->
    <div class="corkboard" id="corkboard">
      <!-- Vents rendered dynamically -->
      <div class="corkboard-empty font-mono" id="corkboard-empty">
        <p>Nimeni n-a zis nimic. Fii primul nebun.</p>
        <p class="corkboard-empty-sub">(nobody said anything. be the first.)</p>
      </div>
    </div>
  </div>
  <TornEdge direction="bottom" fill="var(--deep-black)" />
</section>

<style>
  .ventwall-section { position: relative; padding: var(--space-3xl) var(--space-lg); min-height: 100vh; }
  .ventwall-container { max-width: 900px; margin: 0 auto; }
  .ventwall-title { font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: var(--space-sm); }
  .ventwall-label { display: block; font-size: 0.65rem; color: var(--ash); letter-spacing: 0.15em; margin-bottom: var(--space-xs); }
  .ventwall-subtitle { color: var(--ash); font-size: 0.8rem; margin-bottom: var(--space-xl); letter-spacing: 0.08em; }

  .vent-form-wrapper { margin-bottom: var(--space-2xl); max-width: 500px; }
  .vent-form-footer { display: flex; justify-content: space-between; align-items: center; margin-top: var(--space-sm); }
  .vent-char-count { font-size: 0.7rem; color: var(--ash); }

  .corkboard {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-lg);
    min-height: 200px;
    padding: var(--space-lg);
    background:
      radial-gradient(circle at 20% 30%, rgba(var(--ink-rust-rgb), 0.04) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(var(--sepia-rgb), 0.04) 0%, transparent 50%),
      rgba(var(--deep-black-rgb), 0.02);
    border: 1px dashed rgba(var(--ink-rust-rgb), 0.15);
  }

  .corkboard-empty { grid-column: 1 / -1; text-align: center; color: var(--ash); padding: var(--space-2xl); font-size: 0.9rem; }
  .corkboard-empty-sub { font-size: 0.7rem; opacity: 0.5; margin-top: var(--space-xs); }

  @media (max-width: 768px) {
    .ventwall-section { padding: var(--space-2xl) var(--space-md); }
    .corkboard { grid-template-columns: 1fr; }
  }
</style>

<script>
  // ── Vent Wall Client-Side Logic ──
  const textarea = document.getElementById('vent-textarea') as HTMLTextAreaElement;
  const charCount = document.getElementById('vent-char-count')!;
  const submitBtn = document.getElementById('vent-submit') as HTMLButtonElement;
  const loader = document.getElementById('vent-loader')!;
  const corkboard = document.getElementById('corkboard')!;
  const emptyMsg = document.getElementById('corkboard-empty')!;

  // Overthinking phrases
  const overthinkingPhrases = [
    'Procesăm anxietatea ta...',
    'Salvăm gândul în cosmos...',
    'Aproape. Sau poate nu. De fapt da.',
    'Gândul tău e important. Probabil.',
    'Scriu pe perete... metaforic.',
  ];

  // Char counter
  textarea.addEventListener('input', () => {
    const len = textarea.value.length;
    charCount.textContent = `${len} / 140`;
    charCount.style.color = len > 120 ? 'var(--ink-rust)' : 'var(--ash)';
  });

  // In-memory vents (dev mode — replace with API calls for production)
  interface Vent {
    id: string;
    text: string;
    createdAt: number;
    expiresAt: number;
    reactions: { heart: number; x: number };
  }

  let vents: Vent[] = [];

  function generateId(): string {
    return Math.random().toString(36).substring(2, 10);
  }

  function timeAgo(expiresAt: number): string {
    const diff = expiresAt - Date.now();
    if (diff <= 0) return 'expirat';
    const hours = Math.floor(diff / 3600000);
    const mins = Math.floor((diff % 3600000) / 60000);
    return `dispare în ${hours}h ${mins}m`;
  }

  function renderVent(vent: Vent): HTMLDivElement {
    const rotation = (Math.random() - 0.5) * 10; // ±5deg
    const el = document.createElement('div');
    el.className = 'vent-note';
    el.style.transform = `rotate(${rotation}deg)`;
    el.innerHTML = `
      <p style="margin:0 0 0.5rem">${vent.text}</p>
      <div style="display:flex;justify-content:space-between;align-items:center">
        <span class="font-mono" style="font-size:0.65rem;color:var(--ash)">${timeAgo(vent.expiresAt)}</span>
        <div style="display:flex;gap:0.8rem">
          <button class="vent-react" data-id="${vent.id}" data-type="heart" aria-label="Iubește" style="background:none;border:none;cursor:pointer;font-size:1rem;color:var(--ink-rust)">
            ❤ <span class="font-mono" style="font-size:0.7rem">${vent.reactions.heart}</span>
          </button>
          <button class="vent-react" data-id="${vent.id}" data-type="x" aria-label="Nu" style="background:none;border:none;cursor:pointer;font-size:1rem;color:var(--ash)">
            ✗ <span class="font-mono" style="font-size:0.7rem">${vent.reactions.x}</span>
          </button>
        </div>
      </div>
    `;
    return el;
  }

  function renderAllVents() {
    // Clear existing
    corkboard.querySelectorAll('.vent-note').forEach(n => n.remove());
    
    if (vents.length === 0) {
      emptyMsg.style.display = '';
      return;
    }
    emptyMsg.style.display = 'none';

    vents.forEach(vent => {
      corkboard.appendChild(renderVent(vent));
    });

    // Attach reaction handlers
    corkboard.querySelectorAll('.vent-react').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const id = target.dataset.id!;
        const type = target.dataset.type as 'heart' | 'x';
        const vent = vents.find(v => v.id === id);
        if (vent) {
          vent.reactions[type]++;
          renderAllVents();
        }
      });
    });
  }

  // Submit handler
  submitBtn.addEventListener('click', async () => {
    const text = textarea.value.trim();
    if (!text || text.length > 140) return;

    // Show overthinking loader
    submitBtn.style.display = 'none';
    loader.style.display = '';
    let phraseIdx = 0;
    loader.textContent = overthinkingPhrases[0];
    const phraseInterval = setInterval(() => {
      phraseIdx = (phraseIdx + 1) % overthinkingPhrases.length;
      loader.textContent = overthinkingPhrases[phraseIdx];
    }, 1200);

    // Simulate API delay
    await new Promise(r => setTimeout(r, 2000 + Math.random() * 1000));

    clearInterval(phraseInterval);
    loader.style.display = 'none';
    submitBtn.style.display = '';

    // Create vent (optimistic)
    const now = Date.now();
    const vent: Vent = {
      id: generateId(),
      text,
      createdAt: now,
      expiresAt: now + 86400000,
      reactions: { heart: 0, x: 0 },
    };
    vents.unshift(vent);
    if (vents.length > 20) vents = vents.slice(0, 20);
    
    textarea.value = '';
    charCount.textContent = '0 / 140';
    renderAllVents();
  });

  // Initial render
  renderAllVents();
</script>
