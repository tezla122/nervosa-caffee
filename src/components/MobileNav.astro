---
// MobileNav.astro — Crumpled paper hamburger toggle with full-screen overlay
const sections = [
  { id: 'hero', label: 'Început', emoji: '☕' },
  { id: 'manifesto', label: 'Manifest', emoji: '✍' },
  { id: 'menu', label: 'Meniu', emoji: '📋' },
  { id: 'vent-wall', label: 'Zidul', emoji: '📌' },
  { id: 'location', label: 'Locație', emoji: '📍' },
];
---

<div class="mobile-nav-wrapper" id="mobile-nav">
  <!-- Hamburger button -->
  <button
    class="mobile-hamburger"
    id="mobile-hamburger"
    aria-label="Deschide meniu"
    aria-expanded="false"
    aria-controls="mobile-overlay"
  >
    <span class="hamburger-line line-1"></span>
    <span class="hamburger-line line-2"></span>
    <span class="hamburger-line line-3"></span>
  </button>

  <!-- Full-screen overlay -->
  <div class="mobile-overlay" id="mobile-overlay" aria-hidden="true">
    <div class="overlay-content">
      <p class="overlay-brand font-heading">Nervosa</p>
      <nav class="overlay-nav" aria-label="Navigare mobilă">
        {sections.map((section) => (
          <a
            href={`#${section.id}`}
            class="overlay-link"
            data-section={section.id}
          >
            <span class="overlay-emoji">{section.emoji}</span>
            <span class="overlay-label">{section.label}</span>
          </a>
        ))}
      </nav>
      <p class="overlay-tagline font-mono">overthinking fuel.</p>
    </div>
  </div>
</div>

<style>
  .mobile-nav-wrapper {
    display: none;
  }

  @media (max-width: 768px) {
    .mobile-nav-wrapper {
      display: block;
    }
  }

  .mobile-hamburger {
    position: fixed;
    top: 1.2rem;
    right: 1.2rem;
    z-index: 200;
    width: 44px;
    height: 44px;
    background: rgba(var(--deep-black-rgb), 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(var(--sepia-rgb), 0.3);
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 10px;
    transition: transform 0.3s var(--ease-scribble);
  }

  .mobile-hamburger:hover {
    transform: rotate(-3deg);
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--sepia);
    transition: all 0.3s var(--ease-scribble);
    transform-origin: center;
  }

  .mobile-hamburger.open .line-1 {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .mobile-hamburger.open .line-2 {
    opacity: 0;
    transform: scaleX(0);
  }
  .mobile-hamburger.open .line-3 {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  .mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 150;
    background: rgba(var(--deep-black-rgb), 0.97);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s var(--ease-scribble);
  }

  .mobile-overlay.open {
    opacity: 1;
    visibility: visible;
  }

  .overlay-content {
    text-align: center;
    transform: translateY(20px);
    transition: transform 0.4s var(--ease-scribble) 0.1s;
  }

  .mobile-overlay.open .overlay-content {
    transform: translateY(0);
  }

  .overlay-brand {
    font-size: 2.5rem;
    color: var(--sepia);
    margin-bottom: 2.5rem;
    transform: rotate(-2deg);
  }

  .overlay-nav {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .overlay-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    font-family: var(--font-heading);
    font-size: 1.4rem;
    color: var(--paper-white);
    text-decoration: none;
    padding: 0.6rem 1.5rem;
    transition: all 0.3s;
    border: 1px solid transparent;
  }

  .overlay-link:hover {
    color: var(--sepia);
    border-color: rgba(var(--sepia-rgb), 0.2);
    transform: rotate(-1deg);
  }

  .overlay-emoji {
    font-size: 1.2rem;
  }

  .overlay-tagline {
    margin-top: 2.5rem;
    font-size: 0.8rem;
    color: var(--ash);
    letter-spacing: 0.15em;
  }
</style>

<script>
  const hamburger = document.getElementById('mobile-hamburger')!;
  const overlay = document.getElementById('mobile-overlay')!;
  const links = overlay.querySelectorAll<HTMLAnchorElement>('.overlay-link');

  function toggleMenu() {
    const isOpen = hamburger.classList.toggle('open');
    overlay.classList.toggle('open', isOpen);
    overlay.setAttribute('aria-hidden', String(!isOpen));
    hamburger.setAttribute('aria-expanded', String(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  }

  hamburger.addEventListener('click', toggleMenu);

  links.forEach((link) => {
    link.addEventListener('click', () => {
      hamburger.classList.remove('open');
      overlay.classList.remove('open');
      overlay.setAttribute('aria-hidden', 'true');
      hamburger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && hamburger.classList.contains('open')) {
      toggleMenu();
    }
  });
</script>
