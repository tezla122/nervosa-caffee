---
// MenuSection.astro — Three card styles: graph paper, index card, dark card
import InkBlot from './svg/InkBlot.astro';
import Smudge from './svg/Smudge.astro';
import menuData from '../data/menu.json';
---

<section id="menu" class="section section-dark menu-section">
  <div class="menu-container">
    <h2 class="menu-title heading-tilt-right tear-in">
      <span class="menu-label font-mono">// meniu</span>
      Ce bem azi?
    </h2>

    <!-- Seasonal -->
    <div class="seasonal-banner tear-in">
      <span class="seasonal-badge font-mono">{menuData.seasonal_special.badge}</span>
      <h3 class="seasonal-name">{menuData.seasonal_special.name}</h3>
      <p class="seasonal-desc">{menuData.seasonal_special.description}</p>
      <span class="seasonal-price">{menuData.seasonal_special.price}</span>
    </div>

    <div class="menu-grid">
      <!-- COFFEE — Graph Paper -->
      <div class="menu-card menu-card-graphpaper tear-in">
        <h3 class="card-title heading-tilt-subtle"><InkBlot variant={1} class="card-blot" /> Specialty Coffee</h3>
        {menuData.specialty_coffee.map((item, i) => (
          <div class="menu-item">
            <div class="item-left">
              <InkBlot variant={((i % 3) + 1) as 1|2|3} width="16" height="16" class="item-blot" />
              <div><span class="item-name">{item.name}</span><p class="item-desc">{item.description}</p></div>
            </div>
            <span class="menu-item-price">{item.price}</span>
          </div>
        ))}
      </div>

      <!-- REFRESHING — Index Card -->
      <div class="menu-card menu-card-indexcard tear-in">
        <h3 class="card-title heading-tilt-subtle">Băuturi Răcoritoare</h3>
        {menuData.refreshing_drinks.map((item) => (
          <div class="menu-item item-casual">
            <div class="item-left">
              {item.seasonal && <span class="check" title="Sezonier">✓</span>}
              <div><span class="item-name">{item.name}</span><p class="item-desc">{item.description}</p></div>
            </div>
            <span class="menu-item-price">{item.price}</span>
          </div>
        ))}
      </div>

      <!-- PROTEIN — Dark Card -->
      <div class="menu-card menu-card-dark tear-in">
        <h3 class="card-title card-title-light heading-tilt-subtle">Protein Drinks</h3>
        {menuData.protein_drinks.map((item, i) => (
          <Fragment>
            <div class="menu-item item-dark">
              <div class="item-left">
                <div><span class="item-name name-light">{item.name}</span><p class="item-desc desc-light">{item.description}</p></div>
              </div>
              <span class="menu-item-price price-light">{item.price}</span>
            </div>
            {i < menuData.protein_drinks.length - 1 && <Smudge class="smudge" />}
          </Fragment>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .menu-section { position: relative; padding: var(--space-3xl) var(--space-lg); }
  .menu-container { max-width: 1000px; margin: 0 auto; }
  .menu-title { font-size: clamp(2rem, 5vw, 3.5rem); color: var(--paper-white); margin-bottom: var(--space-xl); }
  .menu-label { display: block; font-size: 0.65rem; color: var(--ash); letter-spacing: 0.15em; margin-bottom: var(--space-xs); }
  .seasonal-banner { background: linear-gradient(135deg, rgba(var(--sepia-rgb),0.15), rgba(var(--ink-rust-rgb),0.1)); border: 2px dashed var(--sepia); padding: var(--space-lg) var(--space-xl); margin-bottom: var(--space-2xl); transform: rotate(-0.5deg); }
  .seasonal-badge { display: inline-block; background: var(--sepia); color: var(--deep-black); padding: 4px 12px; font-size: 0.75rem; letter-spacing: 0.1em; margin-bottom: var(--space-sm); font-weight: bold; }
  .seasonal-name { font-family: var(--font-heading); font-size: 1.5rem; color: var(--sepia); margin: 0 0 var(--space-xs); }
  .seasonal-desc { color: rgba(var(--paper-white-rgb),0.8); font-size: 0.9rem; margin: 0 0 var(--space-sm); }
  .seasonal-price { font-family: var(--font-heading); font-size: 1.4rem; color: var(--sepia); }
  .menu-grid { display: grid; gap: var(--space-xl); }
  @media (min-width: 768px) { .menu-grid { grid-template-columns: 1fr 1fr; } .menu-grid > :first-child { grid-column: 1 / -1; } }
  .card-title { font-family: var(--font-heading); font-size: 1.5rem; margin: 0 0 var(--space-lg); display: flex; align-items: center; gap: var(--space-sm); color: var(--deep-black); }
  .card-title-light { color: var(--paper-white) !important; }
  .card-blot { color: var(--ink-rust); }
  .item-left { display: flex; align-items: flex-start; gap: var(--space-sm); flex: 1; min-width: 0; }
  .item-blot { color: var(--ink-rust); flex-shrink: 0; margin-top: 4px; }
  .item-name { font-family: var(--font-heading); font-size: 1.1rem; color: var(--deep-black); }
  .name-light { color: var(--paper-white) !important; }
  .item-desc { font-size: 0.85rem; color: var(--ash); margin: 2px 0 0; }
  .item-casual { padding: var(--space-md) 0; border-bottom: 1px dashed rgba(var(--ash-rgb),0.15); }
  .item-dark { border-bottom-color: rgba(255,255,255,0.06) !important; }
  .desc-light { color: rgba(var(--paper-white-rgb),0.5) !important; }
  .price-light { color: var(--sepia) !important; }
  .check { font-family: var(--font-heading); color: var(--sepia); font-size: 1.2rem; flex-shrink: 0; }
  .smudge { margin: var(--space-xs) 0; opacity: 0.5; width: 100%; }
  @media (max-width: 768px) { .menu-section { padding: var(--space-2xl) var(--space-md); } }
  @media (max-width: 480px) { 
    .menu-section { padding: var(--space-xl) var(--space-sm); }
    .seasonal-banner { padding: var(--space-md); margin-bottom: var(--space-xl); }
  }
</style>
