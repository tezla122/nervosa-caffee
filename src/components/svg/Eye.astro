---
// Eye.astro — Hand-drawn eye SVG scribble
interface Props {
  class?: string;
  width?: string;
  height?: string;
}

const { class: className = '', width = '70', height = '40' } = Astro.props;
---

<svg
  class={`scribble ${className}`}
  width={width}
  height={height}
  viewBox="0 0 70 40"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <!-- Upper lid -->
  <path
    d="M5 22 C15 5 55 5 65 22"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
  />
  <!-- Lower lid -->
  <path
    d="M5 22 C15 38 55 38 65 22"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
  />
  <!-- Iris -->
  <circle
    cx="35"
    cy="22"
    r="9"
    stroke="currentColor"
    stroke-width="1.3"
  />
  <!-- Pupil -->
  <circle
    cx="35"
    cy="22"
    r="4"
    stroke="currentColor"
    stroke-width="1"
  />
  <!-- Upper lashes -->
  <path d="M15 13 L13 7" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
  <path d="M25 8 L24 2" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
  <path d="M35 6 L35 0" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
  <path d="M45 8 L46 2" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
  <path d="M55 13 L57 7" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
</svg>
