---
// CornerFlourish.astro — Decorative corner flourish SVG
interface Props {
  class?: string;
  corner?: 'top-left' | 'top-right' | 'bottom-left' | 'bottom-right';
}

const { class: className = '', corner = 'top-left' } = Astro.props;

const transforms: Record<string, string> = {
  'top-left': '',
  'top-right': 'scale(-1, 1) translate(-60, 0)',
  'bottom-left': 'scale(1, -1) translate(0, -60)',
  'bottom-right': 'scale(-1, -1) translate(-60, -60)',
};
---

<svg
  class={`scribble ${className}`}
  width="60"
  height="60"
  viewBox="0 0 60 60"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <g transform={transforms[corner]}>
    <path
      d="M5 55 C5 30 10 15 20 10 C30 5 45 8 50 5"
      stroke="currentColor"
      stroke-width="1.2"
      stroke-linecap="round"
    />
    <path
      d="M8 50 C12 35 15 25 25 18"
      stroke="currentColor"
      stroke-width="0.8"
      stroke-linecap="round"
    />
    <circle cx="50" cy="5" r="2" stroke="currentColor" stroke-width="1" />
  </g>
</svg>
