---
// Underline.astro — SVG scribble underline for links
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 200 8"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  preserveAspectRatio="none"
>
  <path
    d="M2 5 C30 2, 50 7, 80 4 C110 1, 130 6, 160 3 C175 2, 190 5, 198 4"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
  />
</svg>
